# .env.example - Copy this file to .env and fill in your values
# DO NOT commit .env to git

# PostgreSQL Database Connection
# Format: host=localhost port=5432 dbname=solriver user=postgres password=postgres
DB_DSN=host=localhost port=5432 dbname=solriver user=postgres password=postgres

# AlsoEnergy Portfolio Key (optional, default is C12941)
PORTFOLIO_KEY=C12941

# API Request Timeout (seconds)
API_TIMEOUT=60

# Sleep between API calls (seconds)
API_SLEEP=1.5
